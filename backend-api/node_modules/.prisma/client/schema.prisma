generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompetitorStatus {
  active
  paused
  error
}

enum PageType {
  home
  pricing
  product
  category
  blog
  docs
  other
}

enum Severity {
  low
  med
  high
}

enum ChangeType {
  content
  visual
  price
  structure
  meta
}

model Competitor {
  id          String           @id @default(uuid())
  domain      String
  displayName String?
  status      CompetitorStatus @default(active)
  lastScanAt  DateTime?
  createdAt   DateTime         @default(now())
  pages       Page[]

  @@unique([domain])
}

model Page {
  id                String     @id @default(uuid())
  competitorId      String
  competitor        Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  url               String
  path              String
  pageType          PageType   @default(other)
  monitoringEnabled Boolean    @default(false)
  checkIntervalMin  Int        @default(60)
  lastCheckedAt     DateTime?
  lastChangeAt      DateTime?
  lastSeverity      Severity?
  createdAt         DateTime   @default(now())

  snapshots PageSnapshot[]
  changes   Change[]

  @@unique([competitorId, url])
}

model PageSnapshot {
  id            String   @id @default(uuid())
  pageId        String
  page          Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  capturedAt    DateTime @default(now())
  httpStatus    Int?
  contentHash   String?
  textExtracted String?
  metaJson      Json?
}

model Change {
  id             String     @id @default(uuid())
  pageId         String
  page           Page       @relation(fields: [pageId], references: [id], onDelete: Cascade)
  fromSnapshotId String?
  toSnapshotId   String
  detectedAt     DateTime   @default(now())
  changeType     ChangeType
  severity       Severity   @default(low)
  summary        String
  diffJson       Json?
  isAcknowledged Boolean    @default(false)
}
